# Copy to .env and fill in. The agent runs in DRY-RUN without these.

# Required for real content generation
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed when you wire up real publishing later.
# The MCP tools available in Claude Code (Buffer, Canva, Gmail, Drive) can
# handle these without keys here; these are for standalone/cron use.
# GUMROAD_ACCESS_TOKEN=
# BUFFER_ACCESS_TOKEN=
